EFG 2 R "Two-country escalation / nuclear crisis game" { "Country A" "Country B" }
""

p "" 1 1 "" { "Escalate" "Ignore" } 0
p "" 2 1 "" { "Back down" "Escalate" } 0
t "" 1 "B backs down" { 2, -1 }
p "" 1 2 "" { "Retreat" "Detonate" } 0
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 2 "Both retreat (lose credibility)" { -1, -1 }
t "" 3 "B detonates, A retreats" { -5, 5 }
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 4 "A detonates, B retreats" { 5, -5 }
t "" 5 "Mutual detonation (catastrophe)" { -10, -10 }
t "" 6 "Ignore: small peace" { 1, 1 }