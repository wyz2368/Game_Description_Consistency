EFG 2 R "Gambler-Casino Matching Pennies" { "Gambler" "Dealer" }
p "" 1 1 "" { "Enter" "Stay out" } 0
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "match_hh" { 1, -1 }
t "" 3 "mismatch_ht" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 4 "mismatch_th" { -1, 1 }
t "" 5 "match_tt" { 1, -1 }
t "" 1 "stay_out" { 0, 0 }