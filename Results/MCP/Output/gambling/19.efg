EFG 2 R "Gambler Matching Pennies" { "Gambler" "Dealer" }
p "" 1 1 "" { "Enter" "Stay out" } 0
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "match_h_h" { 1, -1 }
t "" 3 "mismatch_h_t" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 4 "mismatch_t_h" { -1, 1 }
t "" 5 "match_t_t" { 1, -1 }
t "" 1 "stay_out" { 0, 0 }