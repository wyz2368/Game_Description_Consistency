EFG 2 R "Gambler enters casino and plays matching pennies" { "Gambler" "Dealer" }
p "" 1 1 "" { "Enter" "Stay out" } 0
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 1 "Match H-H" { 1, -1 }
t "" 2 "Mismatch H-T" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "Mismatch T-H" { -1, 1 }
t "" 1 "Match T-T" { 1, -1 }
t "" 3 "Stay out" { 0, 0 }