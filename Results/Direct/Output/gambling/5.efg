EFG 2 R "Gambler entry matching pennies" { "Gambler" "Dealer" }
p "" 1 1 "" { "Enter" "Stay out" } 0
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 1 "Match" { 1, -1 }
t "" 2 "Mismatch" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "Mismatch" { -1, 1 }
t "" 1 "Match" { 1, -1 }
t "" 3 "Stay out" { 0, 0 }