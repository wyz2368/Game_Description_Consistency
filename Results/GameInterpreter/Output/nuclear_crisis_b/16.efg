EFG 2 R "Threat and Crisis (simultaneous crisis stage)" { "Country A" "Country B" }
p "" 1 1 "" { "Issue threat" "Ignore" } 0
p "" 2 1 "" { "Back down" "Counter-threat" } 0
t "" 2 "B backs down" { 2, 1 }
p "" 1 2 "" { "Retreat" "Detonate" } 0
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 3 "mutual retreat" { 0, 1 }
t "" 4 "B wins crisis" { -10, 3 }
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 5 "A wins crisis" { 3, -10 }
t "" 6 "mutual detonation" { -100, -100 }
t "" 1 "ignore" { 1, 2 }