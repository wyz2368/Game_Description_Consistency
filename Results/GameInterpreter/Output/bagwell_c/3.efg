EFG 2 R "Noisy-leader game (epsilon = 0.01)" { "Player 1" "Player 2" }
p "" 1 1 "" { "C" "S" } 0
c "" 1 "" { "Signal C" 99/100 "Signal S" 1/100 } 0
p "" 2 1 "" { "C" "S" } 0
t "" 1 "(C,C)" { 4, 4 }
t "" 2 "(C,S)" { 6, 3 }
