EFG 2 R "Gambler chooses whether to enter; if entering, play Matching Pennies" { "Gambler" "Dealer" }
""

p "" 1 1 "" { "Stay out" "Enter" } 0
t "" 1 "Stay out: no play" { 0, 0 }
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "Match: Gambler wins" { 1, -1 }
t "" 3 "Mismatch: Dealer wins" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 3 "Mismatch: Dealer wins" { -1, 1 }
t "" 2 "Match: Gambler wins" { 1, -1 }
