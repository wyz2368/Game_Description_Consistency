EFG 2 R "Threat / Counter-threat with crisis stage" { "Country A" "Country B" }
""

p "" 1 1 "" { "Threaten" "Ignore" } 0
p "" 2 1 "" { "Back down" "Counter-threat" } 0
t "" 1 "B backs down" { 5, 2 }
p "" 1 2 "" { "Retreat" "Detonate" } 0
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 2 "mutual retreat" { 0, 2 }
t "" 3 "B wins crisis" { -5, 10 }
p "" 2 2 "" { "Retreat" "Detonate" } 0
t "" 4 "A wins crisis" { 10, -5 }
t "" 5 "mutual detonation" { -100, -100 }
t "" 6 "ignore" { 2, 5 }
