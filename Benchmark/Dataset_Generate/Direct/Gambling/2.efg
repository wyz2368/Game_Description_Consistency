EFG 2 R "Gambler enters matching pennies" { "Gambler" "Dealer" }
p "" 1 1 "" { "Stay out" "Enter" } 0
t "" 1 "Stay out" { 0, 0 }
p "" 1 2 "" { "Heads" "Tails" } 0
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 2 "Match - gambler wins" { 1, -1 }
t "" 3 "Mismatch - dealer wins" { -1, 1 }
p "" 2 1 "" { "Heads" "Tails" } 0
t "" 3 "Mismatch - dealer wins" { -1, 1 }
t "" 2 "Match - gambler wins" { 1, -1 }